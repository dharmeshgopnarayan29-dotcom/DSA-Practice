   "source": [
    "# Used to quickly calculate sum of subarrays.\n",
    "\n",
    "def prefix_sum(arr):\n",
    "    prefix = [0]*len(arr)\n",
    "    prefix[0] = arr[0]\n",
    "\n",
    "    for i in range(1, len(arr)):\n",
    "        prefix[i] = prefix[i-1] + arr[i]\n",
    "\n",
    "    return prefix\n",
    "\n",
    "arr = [1,2,3,4,5]\n",
    "prefix_sum(arr)"
   ]
  },
